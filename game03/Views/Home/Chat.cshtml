@{
    ViewData["Title"] = "Chat";
}

<h2>Chat</h2>

<div class="card">
    <div class="card-body">
        <div id="messagesList" style="height:300px; overflow:auto; border:1px solid #ddd; padding:10px; margin-bottom:10px;"></div>

        <div class="mb-2">
            <input id="userInput" class="form-control" placeholder="Your name" />
        </div>
        <div class="input-group">
            <input id="messageInput" class="form-control" placeholder="Type a message..." />
            <button id="sendButton" class="btn btn-primary">Send</button>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SignalR client from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
